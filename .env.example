# Kudosy environment configuration
# Copy this file to .env and adjust values

# Directory where config.yaml, defaults.yaml, settings.json and logs are stored
KUDOSY_DATA_DIR=/data

# Port the web UI listens on
KUDOSY_PORT=8080

# Timezone (for log timestamps and scheduler)
TZ=Europe/Berlin

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
